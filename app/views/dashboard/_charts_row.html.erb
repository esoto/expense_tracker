<section aria-label="<%= t('dashboard.v2.charts_label', default: 'Charts') %>" class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
  <%# === Monthly Trend (placeholder for PER-414) === %>
  <div class="bg-white dark:bg-slate-800 rounded-lg shadow p-4">
    <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100 mb-4">
      <%= t("dashboard.v2.monthly_trend", default: "Monthly Trend") %>
    </h2>
    <%# @monthly_trend — Hash of {date => amount}, 6 months. Chart will be wired in PER-414. %>
    <div class="flex items-center justify-center h-[300px] text-slate-500 dark:text-slate-400">
      <p><%= t("dashboard.v2.monthly_trend_placeholder", default: "Trend chart coming soon") %></p>
    </div>
  </div>

  <%# === Category Breakdown Horizontal Bar Chart === %>
  <div class="bg-white dark:bg-slate-800 rounded-lg shadow p-4" data-controller="chart-skeleton">
    <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100 mb-4">
      <%= t("dashboard.v2.category_breakdown", default: "Category Breakdown") %>
    </h2>

    <% if @category_breakdown.present? %>
      <div class="chart-skeleton-container">
        <div data-chart-skeleton-target="skeleton" class="chart-skeleton-overlay" aria-hidden="true">
          <div class="chart-skeleton-line"></div>
        </div>
        <div data-chart-skeleton-target="chart">
          <%= bar_chart @category_breakdown,
                prefix: "₡",
                thousands: ",",
                height: "300px",
                colors: ["#0F766E"],
                library: { indexAxis: "y" } %>
        </div>
      </div>
    <% else %>
      <div class="flex flex-col items-center justify-center h-[300px] text-slate-500 dark:text-slate-400">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mb-3 text-slate-300 dark:text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
        </svg>
        <p><%= t("dashboard.v2.no_category_data", default: "No hay datos de categorías") %></p>
      </div>
    <% end %>
  </div>
</section>
