<%# Budget detail page %>
<div class="container mx-auto px-4 py-8">
  <div class="max-w-4xl mx-auto">
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-3xl font-bold text-slate-900"><%= @budget.name %></h1>
      <div class="flex gap-2">
        <%= link_to t("common.edit"), edit_budget_path(@budget),
            class: "bg-teal-700 hover:bg-teal-800 text-white font-medium px-4 py-2 rounded-lg shadow-sm transition-colors" %>
        <%= link_to t("common.back"), budgets_path,
            class: "bg-slate-200 hover:bg-slate-300 text-slate-700 font-medium px-4 py-2 rounded-lg transition-colors" %>
      </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6 mb-6">
      <h2 class="text-xl font-semibold text-slate-900 mb-4"><%= t("budgets.show.budget_details_title") %></h2>

      <div class="grid md:grid-cols-2 gap-4">
        <div>
          <p class="text-sm text-slate-500"><%= t("budgets.show.period_label") %></p>
          <p class="font-medium text-slate-900"><%= t("budgets.periods.#{@budget.period}", default: @budget.period.humanize) %></p>
        </div>

        <div>
          <p class="text-sm text-slate-500"><%= t("budgets.show.category_label") %></p>
          <p class="font-medium text-slate-900"><%= @budget.category&.display_name || t("budgets.show.general") %></p>
        </div>

        <div>
          <p class="text-sm text-slate-500"><%= t("budgets.show.amount_label") %></p>
          <p class="font-medium text-slate-900"><%= @budget.formatted_amount %></p>
        </div>

        <div>
          <p class="text-sm text-slate-500"><%= t("budgets.show.currency_label") %></p>
          <p class="font-medium text-slate-900"><%= @budget.currency %></p>
        </div>

        <div>
          <p class="text-sm text-slate-500"><%= t("budgets.show.start_date_label") %></p>
          <p class="font-medium text-slate-900"><%= l(@budget.start_date, format: :long) %></p>
        </div>

        <div>
          <p class="text-sm text-slate-500"><%= t("budgets.show.status_label") %></p>
          <p class="font-medium <%= @budget.active? ? 'text-emerald-600' : 'text-slate-400' %>">
            <%= @budget.active? ? t("budgets.show.status_active") : t("budgets.show.status_inactive") %>
          </p>
        </div>
      </div>
    </div>

    <% if @budget_stats %>
      <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
        <h2 class="text-xl font-semibold text-slate-900 mb-4"><%= t("budgets.show.stats_title") %></h2>

        <div class="grid md:grid-cols-3 gap-4">
          <div>
            <p class="text-sm text-slate-500"><%= t("budgets.show.current_spend_label") %></p>
            <p class="font-medium text-slate-900">
              <%= number_to_currency(@budget_stats[:current_spend], unit: @budget.currency_symbol, precision: 0) %>
            </p>
          </div>

          <div>
            <p class="text-sm text-slate-500"><%= t("budgets.show.usage_percentage_label") %></p>
            <p class="font-medium <%= @budget.status_color %>">
              <%= @budget_stats[:usage_percentage] %>%
            </p>
          </div>

          <div>
            <p class="text-sm text-slate-500"><%= t("budgets.show.remaining_label") %></p>
            <p class="font-medium text-slate-900">
              <%= number_to_currency(@budget_stats[:remaining], unit: @budget.currency_symbol, precision: 0) %>
            </p>
          </div>

          <div>
            <p class="text-sm text-slate-500"><%= t("budgets.show.days_remaining_label") %></p>
            <p class="font-medium text-slate-900"><%= t("budgets.show.days_remaining_value", count: @budget_stats[:days_remaining]) %></p>
          </div>

          <div>
            <p class="text-sm text-slate-500"><%= t("budgets.show.daily_average_needed_label") %></p>
            <p class="font-medium text-slate-900">
              <%= number_to_currency(@budget_stats[:daily_average_needed], unit: @budget.currency_symbol, precision: 0) %>
            </p>
          </div>

          <div>
            <p class="text-sm text-slate-500"><%= t("budgets.show.budget_status_label") %></p>
            <p class="font-medium <%= @budget.status_color %>">
              <%= @budget.status_message %>
            </p>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
