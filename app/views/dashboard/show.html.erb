<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <%# === Header === %>
  <%= render "dashboard/header" %>

  <%= turbo_frame_tag "dashboard-body" do %>
    <%# === Period Selector (inside frame so active state updates) === %>
    <%= render "dashboard/period_selector", period: @period %>

    <%# === Metrics Section === %>
    <section aria-label="<%= t('dashboard.v2.metrics_label', default: 'Monthly metrics') %>">
      <%= render "dashboard/metric_cards" %>
    </section>

    <%# === Insights Section === %>
    <%= render "dashboard/insights_row" %>

    <%# === Budget Section === %>
    <section aria-label="<%= t('dashboard.v2.budgets_label', default: 'Budget progress') %>" class="mb-8">
      <%# Placeholder: budget progress bars will be rendered here %>
    </section>

    <%# === Charts Section === %>
    <%= render "dashboard/charts_row" %>

    <%# === Recent Expenses Section === %>
    <section aria-label="<%= t('dashboard.v2.recent_expenses_label', default: 'Recent expenses') %>">
      <div class="bg-white rounded-lg shadow p-4">
        <h2 class="text-lg font-semibold text-slate-900 mb-4">
          <%= t("dashboard.v2.recent_expenses", default: "Recent Expenses") %>
        </h2>
        <%= render "dashboard/recent_activity" %>
      </div>
    </section>
  <% end %>
</div>
