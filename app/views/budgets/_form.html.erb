<%# Budget form partial %>
<%= form_with(model: budget, local: true, class: "space-y-6") do |form| %>
  <%# email_account is assigned by the controller (scoping_user.email_accounts.first)
      for new records. Serialize it so the M2M create flow works end-to-end. %>
  <%= form.hidden_field :email_account_id %>
  <% if budget.errors.any? %>
    <div class="bg-rose-50 border border-rose-200 text-rose-700 px-4 py-3 rounded-lg">
      <h3 class="font-semibold mb-2"><%= t("budgets.form.errors_title") %></h3>
      <ul class="list-disc list-inside">
        <% budget.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
    <div class="grid md:grid-cols-2 gap-4">
      <div>
        <%= form.label :name, t("budgets.form.name_label"), class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= form.text_field :name,
            class: "w-full px-3 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-teal-500",
            placeholder: t("budgets.form.name_placeholder") %>
      </div>

      <div>
        <%= form.label :period, t("budgets.form.period_label"), class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= form.select :period,
            options_for_select(budget_period_options, budget.period),
            {},
            class: "w-full px-3 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-teal-500" %>
      </div>

      <div>
        <%= form.label :amount, t("budgets.form.amount"), class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= form.number_field :amount,
            class: "w-full px-3 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-teal-500",
            placeholder: "100000",
            step: 1000 %>
      </div>

      <div>
        <%= form.label :currency, t("budgets.form.currency_label"), class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= form.select :currency,
            options_for_select(budget_currency_options, budget.currency),
            {},
            class: "w-full px-3 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-teal-500" %>
      </div>

      <div class="md:col-span-2">
        <%= form.label :category_ids, t("budgets.form.categories_label"), class: "block text-sm font-medium text-slate-700 mb-1" %>
        <div class="border border-slate-300 rounded-lg p-3 max-h-48 overflow-y-auto bg-white">
          <% selected_ids = Array(budget.category_ids).map(&:to_i) %>
          <% @categories.each do |cat| %>
            <label class="flex items-center gap-2 py-1 cursor-pointer text-sm text-slate-700 hover:text-slate-900">
              <%= check_box_tag "budget[category_ids][]", cat.id, selected_ids.include?(cat.id),
                  id: "budget_category_ids_#{cat.id}",
                  class: "rounded border-slate-300 text-teal-600 focus:ring-teal-500" %>
              <%= cat.display_name %>
            </label>
          <% end %>
          <%= hidden_field_tag "budget[category_ids][]", "" %>
        </div>
        <p class="mt-1 text-xs text-slate-500"><%= t("budgets.form.categories_hint") %></p>
      </div>

      <div>
        <%= form.label :salary_bucket, t("budgets.form.salary_bucket_label"), class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= form.select :salary_bucket,
            options_for_select(budget_salary_bucket_options, budget.salary_bucket),
            { include_blank: t("budgets.form.salary_bucket_blank") },
            class: "w-full px-3 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-teal-500" %>
      </div>

      <div>
        <%= form.label :start_date, t("budgets.form.start_date"), class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= form.date_field :start_date,
            class: "w-full px-3 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-teal-500" %>
      </div>

      <div>
        <%= form.label :warning_threshold, t("budgets.form.warning_threshold_label"), class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= form.number_field :warning_threshold,
            class: "w-full px-3 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-teal-500",
            min: 1,
            max: 100 %>
      </div>

      <div>
        <%= form.label :critical_threshold, t("budgets.form.critical_threshold_label"), class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= form.number_field :critical_threshold,
            class: "w-full px-3 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-teal-500",
            min: 1,
            max: 100 %>
      </div>
    </div>

    <div class="mt-4">
      <%= form.label :description, t("budgets.form.description"), class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= form.text_area :description,
          rows: 3,
          class: "w-full px-3 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-teal-500",
          placeholder: t("budgets.form.description_placeholder") %>
    </div>

    <div class="mt-4 flex items-center">
      <%= form.check_box :active, class: "mr-2" %>
      <%= form.label :active, t("budgets.form.active_label"), class: "text-sm text-slate-700" %>
    </div>
  </div>

  <div class="flex justify-end gap-2">
    <%= link_to t("common.cancel"), budgets_path,
        class: "bg-slate-200 hover:bg-slate-300 text-slate-700 font-medium px-4 py-2 rounded-lg transition-colors" %>
    <%= form.submit(budget.new_record? ? t("budgets.form.create") : t("budgets.form.update"),
        class: "bg-teal-700 hover:bg-teal-800 text-white font-medium px-4 py-2 rounded-lg shadow-sm transition-colors cursor-pointer") %>
  </div>
<% end %>
