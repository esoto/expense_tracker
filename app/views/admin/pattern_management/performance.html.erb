<div class="container mx-auto px-4">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6">
    <div>
      <h1 class="text-3xl font-bold text-slate-900"><%= t("admin.pattern_management.performance.title") %></h1>
      <p class="text-slate-600 mt-1"><%= t("admin.pattern_management.performance.subtitle") %></p>
    </div>
    <div class="flex flex-wrap gap-2 mt-4 sm:mt-0">
      <%= link_to admin_patterns_statistics_path, class: "bg-slate-200 hover:bg-slate-300 text-slate-700 px-4 py-2 rounded-lg text-sm font-medium inline-flex items-center" do %>
        <svg aria-hidden="true" class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
        </svg>
        <%= t("admin.pattern_management.performance.view_statistics") %>
      <% end %>
      <%= link_to admin_patterns_path, class: "bg-slate-200 hover:bg-slate-300 text-slate-700 px-4 py-2 rounded-lg text-sm font-medium inline-flex items-center" do %>
        <svg aria-hidden="true" class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
        <%= t("admin.pattern_management.performance.back_to_patterns") %>
      <% end %>
    </div>
  </div>

  <!-- Summary Cards -->
  <% summary = @performance_data[:summary] %>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-4">
      <div class="flex items-center">
        <div class="bg-teal-100 text-teal-700 p-3 rounded-lg">
          <svg aria-hidden="true" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
          </svg>
        </div>
        <div class="ml-4">
          <p class="text-sm text-slate-600"><%= t("admin.pattern_management.performance.total_matches_label") %></p>
          <p class="text-2xl font-bold text-slate-900"><%= number_with_delimiter(summary[:total_matches]) %></p>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-4">
      <div class="flex items-center">
        <div class="bg-amber-100 text-amber-700 p-3 rounded-lg">
          <svg aria-hidden="true" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
          </svg>
        </div>
        <div class="ml-4">
          <p class="text-sm text-slate-600"><%= t("admin.pattern_management.performance.avg_daily_label") %></p>
          <p class="text-2xl font-bold text-slate-900"><%= summary[:avg_daily] %></p>
        </div>
      </div>
    </div>
  </div>

  <!-- Weekly Summary -->
  <% if @performance_data[:weekly].any? %>
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6 mb-6">
      <h2 class="text-lg font-semibold text-slate-900 mb-4"><%= t("admin.pattern_management.performance.weekly_summary_title") %></h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        <% @performance_data[:weekly].last(4).each do |week| %>
          <div class="bg-slate-50 rounded-lg p-3 text-center">
            <p class="text-xs text-slate-500 mb-1"><%= t("admin.pattern_management.performance.week_of") %></p>
            <p class="text-xs font-medium text-slate-700"><%= week[:week_start] %></p>
            <p class="text-xl font-bold text-teal-700 mt-1"><%= number_with_delimiter(week[:total]) %></p>
            <p class="text-xs text-slate-500"><%= t("admin.pattern_management.performance.matches") %></p>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Daily Performance Table -->
  <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden mb-6">
    <div class="px-6 py-4 border-b border-slate-200">
      <h2 class="text-lg font-semibold text-slate-900"><%= t("admin.pattern_management.performance.daily_activity_title") %></h2>
      <p class="text-sm text-slate-500 mt-1"><%= t("admin.pattern_management.performance.daily_activity_subtitle") %></p>
    </div>
    <% recent_days = @performance_data[:daily].last(14).reverse %>
    <% if recent_days.any? { |d| d[:total] > 0 } %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200">
          <thead class="bg-slate-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider"><%= t("admin.pattern_management.performance.col_date") %></th>
              <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider"><%= t("admin.pattern_management.performance.col_total") %></th>
              <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider"><%= t("admin.pattern_management.performance.col_correct") %></th>
              <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider"><%= t("admin.pattern_management.performance.col_incorrect") %></th>
              <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider"><%= t("admin.pattern_management.performance.col_accuracy") %></th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-slate-200">
            <% recent_days.each do |day| %>
              <tr class="hover:bg-slate-50">
                <td class="px-6 py-3 text-sm text-slate-600 font-medium"><%= day[:date] %></td>
                <td class="px-6 py-3 text-sm text-slate-900 font-semibold"><%= number_with_delimiter(day[:total]) %></td>
                <td class="px-6 py-3 text-sm text-emerald-600 font-medium"><%= day[:correct] %></td>
                <td class="px-6 py-3 text-sm text-rose-600 font-medium"><%= day[:incorrect] %></td>
                <td class="px-6 py-3">
                  <% if day[:total] > 0 %>
                    <% accuracy = (day[:correct].to_f / day[:total] * 100).round(1) %>
                    <div class="flex items-center">
                      <div class="w-16 bg-slate-200 rounded-full h-2 mr-2">
                        <div class="<%= accuracy >= 70 ? 'bg-emerald-500' : accuracy >= 40 ? 'bg-amber-500' : 'bg-rose-500' %> h-2 rounded-full"
                             style="width: <%= [accuracy, 100].min %>%"></div>
                      </div>
                      <span class="text-sm font-semibold text-slate-900"><%= accuracy %>%</span>
                    </div>
                  <% else %>
                    <span class="text-slate-400 text-xs"><%= t("admin.pattern_management.performance.no_activity") %></span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="px-6 py-8 text-center">
        <p class="text-sm text-slate-500"><%= t("admin.pattern_management.performance.no_activity_message") %></p>
        <p class="text-xs text-slate-400 mt-1"><%= t("admin.pattern_management.performance.no_activity_hint") %></p>
      </div>
    <% end %>
  </div>

  <!-- JSON API Link -->
  <div class="bg-slate-50 rounded-xl border border-slate-200 p-4">
    <p class="text-sm text-slate-600">
      <%= t("admin.pattern_management.performance.json_api_label") %>
      <%= link_to admin_patterns_performance_path(format: :json), class: "text-teal-700 hover:text-teal-800 font-mono text-xs underline" do %>
        GET /admin/patterns/performance.json
      <% end %>
    </p>
  </div>
</div>
