<% case expense.status %>
<% when 'processed' %>
<span class="inline-flex px-2 py-1 text-xs font-medium rounded-full bg-emerald-100 text-emerald-800">
  <%= t("expenses.status.processed") %>
</span>
<% when 'pending' %>
<span class="inline-flex px-2 py-1 text-xs font-medium rounded-full bg-amber-100 text-amber-800">
  <%= t("expenses.card.status.pending") %>
</span>
<% when 'duplicate' %>
<span class="inline-flex px-2 py-1 text-xs font-medium rounded-full bg-rose-100 text-rose-800">
  <%= t("expenses.card.status.duplicate") %>
</span>
<% when 'failed' %>
<span class="inline-flex px-2 py-1 text-xs font-medium rounded-full bg-rose-100 text-rose-800">
  <%= t("expenses.status.failed") %>
</span>
<% else %>
<span class="inline-flex px-2 py-1 text-xs font-medium rounded-full bg-slate-100 text-slate-800">
  <%= expense.status&.capitalize || t("expenses.card.status.unknown") %>
</span>
<% end %>