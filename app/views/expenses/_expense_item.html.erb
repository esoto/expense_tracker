<%# Unified responsive expense item partial
    Replaces both _expense_card (mobile) and _expense_row (desktop) with a single render.
    Uses responsive Tailwind classes to adapt layout across breakpoints.
    Locals: expense (Expense), categories (Array of Category)
    Context note: this partial is for expenses/index only.
               For the dashboard, _expense_row is still used.
%>
<% controller_name = "inline-actions" %>

<div class="bg-white border-b border-slate-200 hover:bg-slate-50 transition-all duration-200 group relative expense-row-with-actions"
     id="expense_row_<%= expense.id %>"
     data-expense-item
     data-controller="<%= controller_name %> mobile-card"
     data-<%= controller_name %>-expense-id-value="<%= expense.id %>"
     data-<%= controller_name %>-current-status-value="<%= expense.status %>"
     data-mobile-card-expense-id-value="<%= expense.id %>"
     data-mobile-card-expanded-value="false"
     data-mobile-card-selection-mode-value="false"
     data-batch-selection-target="row"
     data-action="click->batch-selection#handleRowClick click->mobile-card#toggleActions touchstart->mobile-card#touchStart touchend->mobile-card#touchEnd touchmove->mobile-card#touchMove keydown.enter->mobile-card#toggleActions keydown.space->mobile-card#toggleActions keydown.escape->mobile-card#collapseActions"
     tabindex="0"
     aria-selected="false"
     aria-label="<%= expense.display_merchant_name || t('expenses.card.no_merchant') %> <%= number_with_delimiter(expense.amount.to_i) %>">

  <%# ——————————————————————————————————————————————————————————
      BATCH SELECTION CHECKBOX (shared, hidden until selection mode)
      ——————————————————————————————————————————————————————————— %>
  <div class="hidden px-4 pt-3 md:hidden" data-mobile-card-target="checkbox">
    <input type="checkbox"
           class="h-4 w-4 text-teal-600 focus:ring-teal-500 border-slate-300 rounded"
           aria-label="Seleccionar gasto <%= expense.display_merchant_name || t('expenses.card.no_merchant') %>"
           data-action="click->mobile-card#toggleCheckbox:stop">
  </div>

  <%# ——————————————————————————————————————————————————————————
      MOBILE LAYOUT (visible on < md)
      Card style: color dot + merchant + amount, then date + category + status
      ——————————————————————————————————————————————————————————— %>
  <div class="px-4 py-3 md:hidden">
    <%# Top row: color dot + merchant + amount %>
    <div class="flex items-center gap-3">
      <% if expense.category %>
        <div class="w-3 h-3 rounded-full flex-shrink-0"
             style="background-color: <%= expense.category.color %>;"
             title="<%= expense.category.display_name %>"></div>
      <% else %>
        <div class="w-3 h-3 rounded-full bg-slate-400 flex-shrink-0"
             title="<%= t('expenses.card.no_category') %>"></div>
      <% end %>

      <span class="flex-1 text-sm font-semibold text-slate-900 truncate min-w-0">
        <% if expense.merchant_name? %>
          <%= expense.display_merchant_name %>
        <% else %>
          <span class="text-rose-600 italic"><%= t('expenses.card.no_merchant') %></span>
        <% end %>
      </span>

      <span class="text-sm font-bold text-slate-900 flex-shrink-0">
        <%= currency_symbol(expense) %><%= number_with_delimiter(expense.amount.to_i) %>
      </span>
    </div>

    <%# Bottom row: date + category + status badge %>
    <div class="flex items-center gap-2 mt-1 pl-6">
      <span class="text-xs text-slate-500">
        <%= expense.transaction_date.strftime("%d/%m/%Y") %>
      </span>

      <% if expense.category %>
        <span class="text-xs text-slate-400">&middot;</span>
        <span id="expense_<%= expense.id %>_category" class="text-xs text-slate-600"><%= expense.category.display_name %></span>
      <% end %>

      <% unless expense.status == "processed" %>
        <span class="text-xs text-slate-400">&middot;</span>
        <span data-testid="status-badge">
          <% case expense.status %>
          <% when "pending" %>
            <span class="inline-flex px-1.5 py-0.5 text-xs font-medium rounded-full bg-amber-100 text-amber-800">
              <%= t('expenses.card.status.pending') %>
            </span>
          <% when "duplicate" %>
            <span class="inline-flex px-1.5 py-0.5 text-xs font-medium rounded-full bg-rose-100 text-rose-800">
              <%= t('expenses.card.status.duplicate') %>
            </span>
          <% when "failed" %>
            <span class="inline-flex px-1.5 py-0.5 text-xs font-medium rounded-full bg-rose-100 text-rose-800">
              <%= t('expenses.card.status.failed') %>
            </span>
          <% else %>
            <span class="inline-flex px-1.5 py-0.5 text-xs font-medium rounded-full bg-slate-100 text-slate-800">
              <%= expense.status&.capitalize || t('expenses.card.status.unknown') %>
            </span>
          <% end %>
        </span>
      <% end %>
    </div>
  </div>

  <%# ——————————————————————————————————————————————————————————
      DESKTOP LAYOUT (visible on md+)
      Table-row style: date | merchant | category | amount | bank | status | actions
      ——————————————————————————————————————————————————————————— %>
  <div class="hidden md:grid md:grid-cols-[40px_100px_1fr_160px_120px_100px_40px] md:items-center md:gap-0">
    <%# Checkbox %>
    <div class="checkbox-cell px-3 py-2.5 flex items-center">
      <input type="checkbox"
             data-batch-selection-target="checkbox"
             data-action="change->batch-selection#toggleSelection click->batch-selection#toggleSelection:stop"
             data-expense-id="<%= expense.id %>"
             class="h-4 w-4 text-teal-600 focus:ring-teal-500 border-slate-300 rounded"
             aria-label="Seleccionar gasto <%= expense.display_merchant_name || 'sin comercio' %> de <%= expense.amount %>">
    </div>

    <%# Date %>
    <div class="px-3 py-2.5 text-[13px] text-slate-600 tabular-nums whitespace-nowrap">
      <%= expense.transaction_date.strftime("%d/%m/%Y") %>
    </div>

    <%# Merchant + Bank (stacked) %>
    <div class="px-3 py-2.5">
      <div class="text-[13px] font-medium text-slate-900 truncate">
        <% if expense.merchant_name? %>
          <%= expense.display_merchant_name %>
        <% else %>
          <span class="text-rose-600 italic"><%= t("expenses.card.no_merchant", default: "Sin comercio") %></span>
        <% end %>
      </div>
      <div class="text-xs text-slate-400"><%= expense.bank_name %></div>
    </div>

    <%# Category (compact: color dot + name, clickable for correction) %>
    <div class="px-3 py-2.5 text-[13px] relative"
         data-controller="category-confidence"
         data-category-confidence-expense-id-value="<%= expense.id %>">
      <turbo-frame id="expense_<%= expense.id %>_category">
        <button class="inline-flex items-center gap-1.5 cursor-pointer hover:ring-2 hover:ring-teal-300 rounded-full px-1 -mx-1 transition-all"
                data-action="click->category-confidence#showCorrection"
                title="<%= t('expenses.actions.change_category', default: 'Click to change category') %>">
          <% if expense.category %>
            <% safe_color = (expense.category.color.to_s.match?(/\A#[0-9a-fA-F]{3,6}\z/) ? expense.category.color : "#64748b") %>
            <span class="w-2 h-2 rounded-full shrink-0" style="background-color: <%= safe_color %>"></span>
            <span class="text-slate-700"><%= expense.category.display_name %></span>
          <% else %>
            <span class="w-2 h-2 rounded-full shrink-0 bg-slate-400"></span>
            <span class="text-slate-500"><%= t("expenses.card.no_category", default: "Sin categoria") %></span>
          <% end %>
        </button>
      </turbo-frame>
    </div>

    <%# Amount %>
    <div class="px-3 py-2.5 text-right text-[13px] font-medium text-slate-900 tabular-nums whitespace-nowrap">
      <%= currency_symbol(expense) %><%= number_with_delimiter(expense.amount.to_i) %>
    </div>

    <%# Status %>
    <div class="px-3 py-2.5 text-center">
      <turbo-frame id="expense_<%= expense.id %>_status">
        <%= render "expenses/status_badge", expense: expense %>
      </turbo-frame>
    </div>

    <%# Kebab Menu %>
    <div id="expense_<%= expense.id %>_actions" class="px-2 py-2.5 text-center">
      <%= render "expenses/kebab_menu", expense: expense %>
    </div>
  </div>

  <%# ——————————————————————————————————————————————————————————
      MOBILE ACTIONS (tap-to-expand, visible on < md)
      ——————————————————————————————————————————————————————————— %>
  <div class="hidden border-t border-slate-100 bg-slate-50 px-4 py-3 md:hidden"
       data-mobile-card-target="actions">
    <div class="flex items-center justify-between gap-2">
      <%# Categorizar %>
      <div class="flex-1 relative">
        <button type="button"
                class="w-full inline-flex flex-col items-center gap-1 py-2 px-3 rounded-lg text-xs font-medium text-teal-700 bg-teal-50 hover:bg-teal-100 transition-colors"
                aria-label="<%= t('expenses.card.actions.categorize_label') %>"
                data-action="click->mobile-card#openCategoryPicker:stop">
          <svg aria-hidden="true" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
          </svg>
          <%= t('expenses.card.actions.categorize') %>
        </button>

        <%# Category dropdown for mobile %>
        <div class="hidden absolute left-0 top-full mt-1 z-10 bg-white rounded-lg shadow-lg border border-slate-200 max-h-48 overflow-y-auto w-48"
             data-mobile-card-target="categoryDropdown">
          <% local_assigns[:categories]&.each do |cat| %>
            <button type="button"
                    class="w-full px-3 py-2.5 text-left text-xs text-slate-700 hover:bg-slate-50 flex items-center gap-2"
                    data-action="click->mobile-card#selectCategory:stop"
                    data-category-id="<%= cat.id %>"
                    data-category-name="<%= cat.display_name %>"
                    role="option">
              <span class="inline-block w-3 h-3 rounded-full flex-shrink-0" style="background-color: <%= cat.color %>"></span>
              <%= cat.display_name %>
            </button>
          <% end %>
        </div>
      </div>

      <%# Estado %>
      <button type="button"
              class="flex-1 inline-flex flex-col items-center gap-1 py-2 px-3 rounded-lg text-xs font-medium text-emerald-700 bg-emerald-50 hover:bg-emerald-100 transition-colors"
              aria-label="<%= t('expenses.card.actions.status_label') %>"
              data-action="click->mobile-card#toggleStatus:stop">
        <svg aria-hidden="true" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <%= t('expenses.card.actions.status') %>
      </button>

      <%# Editar %>
      <%= link_to edit_expense_path(expense),
            class: "flex-1 inline-flex flex-col items-center gap-1 py-2 px-3 rounded-lg text-xs font-medium text-slate-700 bg-slate-100 hover:bg-slate-200 transition-colors",
            aria: { label: t('expenses.card.actions.edit_label') },
            data: { action: "click:stop" } do %>
        <svg aria-hidden="true" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
        </svg>
        <%= t('common.edit') %>
      <% end %>

      <%# Eliminar %>
      <button type="button"
              class="flex-1 inline-flex flex-col items-center gap-1 py-2 px-3 rounded-lg text-xs font-medium text-rose-700 bg-rose-50 hover:bg-rose-100 transition-colors"
              aria-label="<%= t('expenses.card.actions.delete_label') %>"
              data-action="click->mobile-card#confirmDelete:stop">
        <svg aria-hidden="true" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
        </svg>
        <%= t('common.delete') %>
      </button>
    </div>
  </div>
</div>
