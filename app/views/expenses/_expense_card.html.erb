<%# Mobile expense card partial
    Locals: expense (Expense), categories (Array of Category)
%>
<article class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden"
         id="expense_card_<%= expense.id %>"
         tabindex="0"
         aria-label="<%= expense.merchant_name || 'Sin comercio' %> <%= number_with_delimiter(expense.amount.to_i) %>"
         data-controller="mobile-card"
         data-mobile-card-expense-id-value="<%= expense.id %>"
         data-mobile-card-expanded-value="false"
         data-mobile-card-selection-mode-value="false"
         data-action="click->mobile-card#toggleActions touchstart->mobile-card#touchStart touchend->mobile-card#touchEnd touchmove->mobile-card#touchMove keydown.enter->mobile-card#toggleActions keydown.space->mobile-card#toggleActions keydown.escape->mobile-card#collapseActions">

  <%# Batch selection checkbox — hidden by default, shown in selection mode %>
  <div class="hidden px-4 pt-3" data-mobile-card-target="checkbox">
    <input type="checkbox"
           class="h-4 w-4 text-teal-600 focus:ring-teal-500 border-slate-300 rounded"
           aria-label="Seleccionar gasto <%= expense.merchant_name || 'sin comercio' %>"
           data-action="click->mobile-card#toggleCheckbox:stop">
  </div>

  <%# Main card content %>
  <div class="px-4 py-3">
    <%# Top row: color dot + merchant name + amount %>
    <div class="flex items-center gap-3">
      <%# Category color dot %>
      <% if expense.category %>
        <div class="w-3 h-3 rounded-full flex-shrink-0"
             style="background-color: <%= expense.category.color %>;"
             title="<%= expense.category.name %>"></div>
      <% else %>
        <div class="w-3 h-3 rounded-full bg-slate-400 flex-shrink-0"
             title="Sin categoría"></div>
      <% end %>

      <%# Merchant name (truncated) %>
      <span class="flex-1 text-sm font-semibold text-slate-900 truncate min-w-0">
        <% if expense.merchant_name? %>
          <%= expense.merchant_name %>
        <% else %>
          <span class="text-rose-600 italic">Sin comercio</span>
        <% end %>
      </span>

      <%# Amount — right aligned %>
      <span class="text-sm font-bold text-slate-900 flex-shrink-0">
        ₡<%= number_with_delimiter(expense.amount.to_i) %>
      </span>
    </div>

    <%# Bottom row: date + category name + optional status badge %>
    <div class="flex items-center gap-2 mt-1 pl-6">
      <span class="text-xs text-slate-500">
        <%= expense.transaction_date.strftime("%d/%m/%Y") %>
      </span>

      <% if expense.category %>
        <span class="text-xs text-slate-400">&middot;</span>
        <span class="text-xs text-slate-600"><%= expense.category.name %></span>
      <% end %>

      <%# Status badge — hidden when processed %>
      <% unless expense.status == "processed" %>
        <span class="text-xs text-slate-400">&middot;</span>
        <span data-testid="status-badge">
          <% case expense.status %>
          <% when "pending" %>
            <span class="inline-flex px-1.5 py-0.5 text-xs font-medium rounded-full bg-amber-100 text-amber-800">
              Pendiente
            </span>
          <% when "duplicate" %>
            <span class="inline-flex px-1.5 py-0.5 text-xs font-medium rounded-full bg-rose-100 text-rose-800">
              Duplicado
            </span>
          <% when "failed" %>
            <span class="inline-flex px-1.5 py-0.5 text-xs font-medium rounded-full bg-rose-100 text-rose-800">
              Fallido
            </span>
          <% else %>
            <span class="inline-flex px-1.5 py-0.5 text-xs font-medium rounded-full bg-slate-100 text-slate-800">
              <%= expense.status&.capitalize || "Desconocido" %>
            </span>
          <% end %>
        </span>
      <% end %>
    </div>
  </div>

  <%# Expandable actions section — hidden by default %>
  <div class="hidden border-t border-slate-100 bg-slate-50 px-4 py-3"
       data-mobile-card-target="actions">
    <div class="flex items-center justify-between gap-2">
      <%# Categorizar %>
      <button type="button"
              class="flex-1 inline-flex flex-col items-center gap-1 py-2 px-3 rounded-lg text-xs font-medium text-teal-700 bg-teal-50 hover:bg-teal-100 transition-colors"
              aria-label="Categorizar gasto"
              data-action="click->mobile-card#openCategoryPicker:stop">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
        </svg>
        Categoría
      </button>

      <%# Estado %>
      <button type="button"
              class="flex-1 inline-flex flex-col items-center gap-1 py-2 px-3 rounded-lg text-xs font-medium text-emerald-700 bg-emerald-50 hover:bg-emerald-100 transition-colors"
              aria-label="Cambiar estado del gasto"
              data-action="click->mobile-card#toggleStatus:stop">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        Estado
      </button>

      <%# Editar %>
      <%= link_to edit_expense_path(expense),
            class: "flex-1 inline-flex flex-col items-center gap-1 py-2 px-3 rounded-lg text-xs font-medium text-slate-700 bg-slate-100 hover:bg-slate-200 transition-colors",
            aria: { label: "Editar gasto" },
            data: { action: "click:stop" } do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
        </svg>
        Editar
      <% end %>

      <%# Eliminar %>
      <button type="button"
              class="flex-1 inline-flex flex-col items-center gap-1 py-2 px-3 rounded-lg text-xs font-medium text-rose-700 bg-rose-50 hover:bg-rose-100 transition-colors"
              aria-label="Eliminar gasto"
              data-action="click->mobile-card#confirmDelete:stop">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
        </svg>
        Eliminar
      </button>
    </div>
  </div>
</article>
