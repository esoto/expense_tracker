# Template for .kamal/secrets. Copy to `.kamal/secrets` (gitignored) and fill
# in real values. Wrap every value in SINGLE QUOTES — Kamal 2's dotenv parser
# does shell-style `$VAR` interpolation on unquoted values, which silently
# corrupts any secret containing a literal `$`.
#
# Verify after editing:
#   kamal secrets print | awk -F= '/^[A-Z]/ {printf "%-28s length=%d\n", $1, length($0)-length($1)-1}'

# GitHub Container Registry PAT with write:packages scope
KAMAL_REGISTRY_PASSWORD='ghp_your_classic_pat_here'

# Rails master key — must match config/master.key exactly (32 hex chars)
RAILS_MASTER_KEY='your_master_key_here'

# Rails secret_key_base — 128 hex chars. Either paste the value from
# `bin/rails credentials:show` or generate a new one with `bin/rails secret`.
SECRET_KEY_BASE='your_secret_key_base_here'

# PostgreSQL password for the expense_tracker user (set during VPS bootstrap)
POSTGRES_PASSWORD='your_postgres_password'

# Admin panel credentials — seeded into AdminUser on first boot via db/seeds.rb
# Production deploys MUST override the dev defaults; db/seeds.rb aborts otherwise.
ADMIN_EMAIL='you@example.com'
ADMIN_PASSWORD='a_strong_password'
