<%# Budget management page %>
<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-slate-900"><%= t("budgets.index.title") %></h1>
    <%= link_to t("budgets.index.new_budget"), new_budget_path,
        class: "bg-teal-700 hover:bg-teal-800 text-white font-medium px-4 py-2 rounded-lg shadow-sm transition-colors",
        data: { turbo_frame: "_top" } %>
  </div>

  <% if @bucket_summary.any? %>
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-slate-700 mb-4"><%= t("budgets.buckets.overview_title") %></h2>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <% @bucket_summary.each do |bucket| %>
          <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-4">
            <p class="text-xs uppercase tracking-wide text-slate-500 mb-1"><%= bucket.label %></p>
            <p class="text-lg font-semibold text-slate-900">
              <%= number_to_currency(bucket.spent, unit: "₡", separator: ",", delimiter: ".", precision: 0, format: "%u%n") %>
              <span class="text-sm font-normal text-slate-500">/
                <%= number_to_currency(bucket.budgeted, unit: "₡", separator: ",", delimiter: ".", precision: 0, format: "%u%n") %>
              </span>
            </p>
            <p class="text-xs text-slate-500 mt-1">
              <%= t("budgets.buckets.remaining") %>:
              <span class="<%= bucket.remaining.negative? ? 'text-rose-600' : 'text-emerald-600' %> font-medium">
                <%= number_to_currency(bucket.remaining, unit: "₡", separator: ",", delimiter: ".", precision: 0, format: "%u%n") %>
              </span>
            </p>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>

  <% if @budgets.any? %>
    <% @budgets_by_period.each do |period, budgets| %>
      <div class="mb-8">
        <h2 class="text-xl font-semibold text-slate-700 mb-4">
          <%= t("budgets.periods.#{period}", default: period.humanize) %>
        </h2>

        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          <% budgets.each do |budget| %>
            <%= render "budgets/card", budget: budget, categories: @category_options %>
          <% end %>
        </div>
      </div>
    <% end %>
  <% elsif @has_external_source %>
    <div class="bg-slate-50 rounded-lg p-8 text-center">
      <p class="text-slate-600"><%= t("budgets.empty_state.sync_in_progress") %></p>
    </div>
  <% else %>
    <%= render "budgets/external_source_empty_state" %>
  <% end %>
</div>
