<div class="container mx-auto px-4 max-w-4xl">
  <div class="mb-6">
    <div class="flex items-center space-x-2 text-sm text-slate-500 mb-3">
      <%= link_to "Patrones Compuestos", admin_composite_patterns_path, class: "hover:text-teal-600" %>
      <span>/</span>
      <%= link_to @composite_pattern.name, admin_composite_pattern_path(@composite_pattern), class: "hover:text-teal-600" %>
      <span>/</span>
      <span class="text-slate-700"><%= t("admin.composite_patterns.breadcrumb.edit") %></span>
    </div>
    <h1 class="text-3xl font-bold text-slate-900"><%= t("admin.composite_patterns.edit.title") %></h1>
    <p class="text-slate-600 mt-1"><%= t("admin.composite_patterns.edit.subtitle") %>: <strong><%= @composite_pattern.name %></strong></p>
  </div>

  <% if @composite_pattern.usage_count > 0 %>
    <div class="mb-6 bg-amber-50 border border-amber-200 text-amber-700 px-4 py-3 rounded-lg flex items-start">
      <svg aria-hidden="true" class="w-5 h-5 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
      </svg>
      <div>
        <p class="font-medium"><%= t("admin.composite_patterns.edit.usage_warning_title") %></p>
        <p class="text-sm mt-0.5"><%= t("admin.composite_patterns.edit.usage_warning_body", count: @composite_pattern.usage_count, rate: ((@composite_pattern.success_rate || 0) * 100).round) %></p>
      </div>
    </div>
  <% end %>

  <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
    <%= render 'form' %>
  </div>
</div>
